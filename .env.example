# Headless Markets — Environment Variables
# Copy to .env.local for local dev, configure in Vercel dashboard for production

# Site
NEXT_PUBLIC_SITE_URL=https://headless-markets.vercel.app

# Base L2
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org

# Contracts
NEXT_PUBLIC_AGENT_REGISTRY=0xE9859D90Ac8C026A759D9D0E6338AE7F9f66467F
NEXT_PUBLIC_TREASURY=0xe5e3A48286288E241A4b5Fb526cC050b830FBA29
NEXT_PUBLIC_POOL=0xDb32c33fC9E2B6a0684CA59dd7Bc78E5c87e1f18

# x402 Payments
NEXT_PUBLIC_X402_ENABLED=true
X402_PAYMENT_ADDRESS=0xe5e3A48286288E241A4b5Fb526cC050b830FBA29
X402_NETWORK=base-mainnet
X402_CHAIN_ID=8453

# Protocol Fee
PROTOCOL_FEE_BPS=1000
TREASURY_ADDRESS=0xe5e3A48286288E241A4b5Fb526cC050b830FBA29

# A2A Discovery
NEXT_PUBLIC_A2A_MANIFEST_URL=https://headless-markets.vercel.app/.well-known/agent.json
